#!/bin/sh
# Fast gate before every commit: formatting + lint + types.
# Full gate (tests, duplication) runs on pre-push and in CI.
set -e

echo "[pre-commit] eslint + tsc"
npm run --silent gate

if git diff --cached --name-only | grep -q '\.java$'; then
  echo "[pre-commit] spotless + checkstyle (java staged)"
  mvn -q -B spotless:check checkstyle:check
fi

echo "[pre-commit] OK"
